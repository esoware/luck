---
source: crates/luck_bundler/tests/integration.rs
expression: output
---
do
local __luck_modules={}
local __luck_loaded={}
local __luck_loading={}
local function __luck_require(id)
local value=__luck_loaded[id]
if value~=nil then
if value==__luck_loading then error("luck bundle: require cycle hit while loading module #"..id,2)end
return value
end
__luck_loaded[id]=__luck_loading
value=__luck_modules[id](id)
if value==nil then value=true end
__luck_loaded[id]=value
return value
end
-- module #1: __luck_greeter
__luck_modules[1]=function(...)
local greeter = {}

function greeter.hello(name: string): string
    local msg = `hello {name}`
    return msg
end

function greeter.farewell(name: string, time: string): string
    return `goodbye {name}, see you at {time}`
end

return greeter
end
local greeter = __luck_require(1)

local result = greeter.hello("world")
print(result)
return result
end
