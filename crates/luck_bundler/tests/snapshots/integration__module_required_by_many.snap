---
source: crates/luck_bundler/tests/integration.rs
expression: output
---
do
local __luck_modules={}
local __luck_loaded={}
local __luck_loading={}
local function __luck_require(id)
local value=__luck_loaded[id]
if value~=nil then
if value==__luck_loading then error("luck bundle: require cycle hit while loading module #"..id,2)end
return value
end
__luck_loaded[id]=__luck_loading
value=__luck_modules[id](id)
if value==nil then value=true end
__luck_loaded[id]=value
return value
end
-- module #1: __luck_shared
__luck_modules[1]=function(...)
local shared = {
    base = 100
}

return shared
end
-- module #2: __luck_a
__luck_modules[2]=function(...)
local shared = __luck_require(1)

local a = {}

function a.value()
    return shared.base + 1
end

return a
end
-- module #3: __luck_b
__luck_modules[3]=function(...)
local shared = __luck_require(1)

local b = {}

function b.value()
    return shared.base + 2
end

return b
end
local a = __luck_require(2)
local b = __luck_require(3)

local result = a.value() + b.value()
print(result)
return result
end
