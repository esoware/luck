{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Luau",
  "scopeName": "source.luau",
  "fileTypes": ["luau"],
  "patterns": [
    { "include": "#comment" },
    { "include": "#type-declaration" },
    { "include": "#statement" }
  ],
  "repository": {
    "statement": {
      "patterns": [
        { "include": "#return-statement" },
        { "include": "#goto-statement" },
        { "include": "#label-statement" },
        { "include": "#continue-keyword" },
        { "include": "#control-keyword" },
        { "include": "#function-declaration" },
        { "include": "#local-declaration" },
        { "include": "#compound-assignment" },
        { "include": "#expression" }
      ]
    },

    "expression": {
      "patterns": [
        { "include": "#comment" },
        { "include": "#interpolated-string" },
        { "include": "#string" },
        { "include": "#number" },
        { "include": "#constant" },
        { "include": "#if-expression" },
        { "include": "#typeof-call" },
        { "include": "#type-cast" },
        { "include": "#operator" },
        { "include": "#vararg" },
        { "include": "#self" },
        { "include": "#function-expression" },
        { "include": "#table-constructor" },
        { "include": "#stdlib-namespace" },
        { "include": "#stdlib-roblox-namespace" },
        { "include": "#stdlib-global" },
        { "include": "#stdlib-constant" },
        { "include": "#stdlib-roblox-global" },
        { "include": "#roblox-datamodel-global" },
        { "include": "#property-call" },
        { "include": "#property-access" },
        { "include": "#function-call" },
        { "include": "#identifier" }
      ]
    },

    "comment": {
      "patterns": [
        {
          "name": "comment.block.documentation.luau",
          "begin": "(--)\\[(=*)\\[(?=\\s*@)",
          "beginCaptures": { "0": { "name": "punctuation.definition.comment.luau" } },
          "end": "\\]\\2\\]",
          "endCaptures": { "0": { "name": "punctuation.definition.comment.luau" } },
          "patterns": [{ "include": "#luadoc" }]
        },
        {
          "name": "comment.block.luau",
          "begin": "--\\[(=*)\\[",
          "beginCaptures": { "0": { "name": "punctuation.definition.comment.luau" } },
          "end": "\\]\\1\\]",
          "endCaptures": { "0": { "name": "punctuation.definition.comment.luau" } }
        },
        {
          "name": "comment.line.documentation.luau",
          "begin": "---(?=\\s*@)",
          "beginCaptures": { "0": { "name": "punctuation.definition.comment.luau" } },
          "end": "$",
          "patterns": [{ "include": "#luadoc" }]
        },
        {
          "name": "comment.line.double-dash.luau",
          "match": "(--).*$",
          "captures": { "1": { "name": "punctuation.definition.comment.luau" } }
        }
      ]
    },

    "luadoc": {
      "patterns": [
        {
          "name": "storage.type.annotation.luau",
          "match": "@(param|return|type|class|field|generic|alias|overload|see|usage|deprecated|nodiscard|async|private|protected|public|since|version|module|meta|within)\\b"
        },
        {
          "name": "entity.name.type.luau",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },

    "string": {
      "patterns": [
        {
          "name": "string.quoted.double.luau",
          "begin": "\"",
          "end": "\"|(?=$)",
          "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.luau" } },
          "endCaptures":   { "0": { "name": "punctuation.definition.string.end.luau" } },
          "patterns": [{ "include": "#string-escape" }]
        },
        {
          "name": "string.quoted.single.luau",
          "begin": "'",
          "end": "'|(?=$)",
          "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.luau" } },
          "endCaptures":   { "0": { "name": "punctuation.definition.string.end.luau" } },
          "patterns": [{ "include": "#string-escape" }]
        },
        {
          "name": "string.quoted.other.long.luau",
          "begin": "\\[(=*)\\[",
          "end": "\\]\\1\\]",
          "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.luau" } },
          "endCaptures":   { "0": { "name": "punctuation.definition.string.end.luau" } }
        }
      ]
    },

    "interpolated-string": {
      "name": "string.template.luau",
      "begin": "`",
      "end": "`",
      "beginCaptures": { "0": { "name": "punctuation.definition.string.template.begin.luau" } },
      "endCaptures":   { "0": { "name": "punctuation.definition.string.template.end.luau" } },
      "patterns": [
        { "include": "#string-escape" },
        {
          "name": "meta.interpolation.luau",
          "begin": "\\{",
          "end": "\\}",
          "beginCaptures": { "0": { "name": "punctuation.section.interpolation.begin.luau" } },
          "endCaptures":   { "0": { "name": "punctuation.section.interpolation.end.luau" } },
          "patterns": [{ "include": "#expression" }]
        }
      ]
    },

    "string-escape": {
      "patterns": [
        { "name": "constant.character.escape.luau", "match": "\\\\(a|b|f|n|r|t|v|\\\\|'|\"|`|\\?)" },
        { "name": "constant.character.escape.byte.luau", "match": "\\\\\\d{1,3}" },
        { "name": "constant.character.escape.hex.luau", "match": "\\\\x[0-9A-Fa-f]{2}" },
        { "name": "constant.character.escape.unicode.luau", "match": "\\\\u\\{[0-9A-Fa-f]+\\}" },
        { "name": "constant.character.escape.linecontinuation.luau", "match": "\\\\z" },
        { "name": "invalid.illegal.unrecognized-escape.luau", "match": "\\\\." }
      ]
    },

    "number": {
      "patterns": [
        {
          "name": "constant.numeric.hex.float.luau",
          "match": "\\b0[xX][0-9A-Fa-f_]+(\\.[0-9A-Fa-f_]*)?([pP][-+]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.hex.luau",
          "match": "\\b0[xX][0-9A-Fa-f_]+\\b"
        },
        {
          "name": "constant.numeric.binary.luau",
          "match": "\\b0[bB][01_]+\\b"
        },
        {
          "name": "constant.numeric.float.luau",
          "match": "\\b\\d[\\d_]*\\.[\\d_]*([eE][-+]?\\d+)?\\b|\\B\\.\\d[\\d_]*([eE][-+]?\\d+)?\\b|\\b\\d[\\d_]*[eE][-+]?\\d+\\b"
        },
        {
          "name": "constant.numeric.decimal.luau",
          "match": "\\b\\d[\\d_]*\\b"
        }
      ]
    },

    "constant": {
      "patterns": [
        { "name": "constant.language.luau", "match": "\\b(true|false|nil)\\b" }
      ]
    },

    "control-keyword": {
      "name": "keyword.control.luau",
      "match": "\\b(if|then|else|elseif|end|do|while|for|in|repeat|until|break|return|goto)\\b"
    },

    "continue-keyword": {
      "name": "keyword.control.continue.luau",
      "match": "\\bcontinue\\b(?=\\s*(--|$|;))"
    },

    "if-expression": {
      "name": "meta.if-expression.luau",
      "begin": "(?<=[=\\(,]|\\breturn\\b)\\s*(if)\\b",
      "beginCaptures": { "1": { "name": "keyword.control.luau" } },
      "end": "(?=$|;|\\bend\\b|\\bdo\\b|,|\\)|\\})",
      "patterns": [
        { "name": "keyword.control.luau", "match": "\\b(then|else|elseif)\\b" },
        { "include": "#expression" }
      ]
    },

    "operator": {
      "patterns": [
        { "name": "keyword.operator.logical.luau", "match": "\\b(and|or|not)\\b" },
        { "name": "keyword.operator.bitwise.luau", "match": "<<|>>|~|&|\\|" },
        { "name": "keyword.operator.comparison.luau", "match": "==|~=|<=|>=|<|>" },
        { "name": "keyword.operator.compound.luau", "match": "\\+=|-=|\\*=|//=|/=|%=|\\^=|\\.\\.=" },
        { "name": "keyword.operator.assignment.luau", "match": "=" },
        { "name": "keyword.operator.arithmetic.luau", "match": "\\+|-|\\*|//|/|%|\\^|#" },
        { "name": "keyword.operator.concatenation.luau", "match": "\\.\\." },
        { "name": "keyword.operator.type-cast.luau", "match": "::" }
      ]
    },

    "compound-assignment": {
      "match": "([A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*)\\s*(\\+=|-=|\\*=|//=|/=|%=|\\^=|\\.\\.=)",
      "captures": {
        "1": { "name": "variable.other.luau" },
        "2": { "name": "keyword.operator.compound.luau" }
      }
    },

    "type-cast": {
      "begin": "(::)\\s*",
      "beginCaptures": { "1": { "name": "keyword.operator.type-cast.luau" } },
      "end": "(?=[,;\\)\\}\\]]|\\bthen\\b|\\bdo\\b|\\bend\\b|\\bor\\b|\\band\\b|=|\\+|-|\\*|/|%|\\^|<|>|~|#|\\|)",
      "patterns": [{ "include": "#type-expression" }]
    },

    "vararg": { "name": "variable.language.vararg.luau", "match": "\\.\\.\\." },
    "self":   { "name": "variable.language.self.luau",   "match": "\\bself\\b" },

    "return-statement": {
      "name": "meta.return.luau",
      "begin": "\\b(return)\\b",
      "beginCaptures": { "1": { "name": "keyword.control.luau" } },
      "end": "(?=$|;|\\bend\\b|\\belse\\b|\\belseif\\b|\\buntil\\b)",
      "patterns": [{ "include": "#expression" }]
    },

    "goto-statement": {
      "match": "\\b(goto)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
      "captures": {
        "1": { "name": "keyword.control.luau" },
        "2": { "name": "entity.name.label.luau" }
      }
    },

    "label-statement": {
      "match": "::([A-Za-z_][A-Za-z0-9_]*)::",
      "captures": { "1": { "name": "entity.name.label.luau" } }
    },

    "type-declaration": {
      "name": "meta.type.declaration.luau",
      "begin": "\\b(export\\s+)?(type)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(<[^>]+>)?\\s*(=)",
      "beginCaptures": {
        "1": { "name": "storage.modifier.export.luau" },
        "2": { "name": "storage.type.type-alias.luau" },
        "3": { "name": "entity.name.type.alias.luau" },
        "4": { "patterns": [{ "include": "#generic-parameters" }] },
        "5": { "name": "keyword.operator.assignment.luau" }
      },
      "end": "(?=$|;|\\blocal\\b|\\bfunction\\b|\\bif\\b|\\bfor\\b|\\bwhile\\b|\\breturn\\b|\\bdo\\b|\\brepeat\\b|\\btype\\b|\\bexport\\b)",
      "patterns": [{ "include": "#type-expression" }]
    },

    "type-expression": {
      "patterns": [
        { "include": "#comment" },
        {
          "name": "keyword.operator.type.luau",
          "match": "\\?|\\||&|->"
        },
        {
          "name": "support.type.primitive.luau",
          "match": "\\b(any|never|unknown|nil|boolean|number|string|thread|userdata|buffer|function|table|vector)\\b"
        },
        {
          "name": "string.quoted.double.luau",
          "begin": "\"",
          "end": "\"",
          "patterns": [{ "include": "#string-escape" }]
        },
        {
          "name": "string.quoted.single.luau",
          "begin": "'",
          "end": "'",
          "patterns": [{ "include": "#string-escape" }]
        },
        {
          "name": "entity.name.type.luau",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        },
        {
          "begin": "\\{",
          "end": "\\}",
          "patterns": [{ "include": "#type-expression" }]
        },
        {
          "begin": "\\(",
          "end": "\\)",
          "patterns": [{ "include": "#type-expression" }]
        },
        {
          "begin": "<",
          "end": ">",
          "patterns": [{ "include": "#type-expression" }]
        },
        {
          "match": "[A-Za-z_][A-Za-z0-9_]*",
          "name": "entity.name.type.luau"
        }
      ]
    },

    "generic-parameters": {
      "patterns": [
        { "name": "entity.name.type.parameter.luau", "match": "[A-Za-z_][A-Za-z0-9_]*" },
        { "name": "variable.language.vararg.type.luau", "match": "\\.\\.\\." }
      ]
    },

    "function-declaration": {
      "patterns": [
        {
          "name": "meta.function.declaration.local.luau",
          "begin": "\\b(local)\\s+(function)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(<[^>]+>)?",
          "beginCaptures": {
            "1": { "name": "storage.modifier.local.luau" },
            "2": { "name": "storage.type.function.luau" },
            "3": { "name": "entity.name.function.luau" },
            "4": { "patterns": [{ "include": "#generic-parameters" }] }
          },
          "end": "(?=\\()"
        },
        {
          "name": "meta.function.declaration.method.luau",
          "begin": "\\b(function)\\s+([A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*)(:)([A-Za-z_][A-Za-z0-9_]*)\\s*(<[^>]+>)?",
          "beginCaptures": {
            "1": { "name": "storage.type.function.luau" },
            "2": { "name": "variable.other.luau" },
            "3": { "name": "punctuation.separator.method.luau" },
            "4": { "name": "entity.name.function.luau" },
            "5": { "patterns": [{ "include": "#generic-parameters" }] }
          },
          "end": "(?=\\()"
        },
        {
          "name": "meta.function.declaration.luau",
          "begin": "\\b(function)\\s+([A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*)\\s*(<[^>]+>)?",
          "beginCaptures": {
            "1": { "name": "storage.type.function.luau" },
            "2": { "name": "entity.name.function.luau" },
            "3": { "patterns": [{ "include": "#generic-parameters" }] }
          },
          "end": "(?=\\()"
        }
      ]
    },

    "function-expression": {
      "name": "meta.function.anonymous.luau",
      "begin": "\\b(function)\\s*(<[^>]+>)?\\s*(?=\\()",
      "beginCaptures": {
        "1": { "name": "storage.type.function.luau" },
        "2": { "patterns": [{ "include": "#generic-parameters" }] }
      },
      "end": "\\b(end)\\b",
      "endCaptures": { "1": { "name": "keyword.control.luau" } },
      "patterns": [
        { "include": "#parameter-list" },
        { "include": "#return-type-annotation" },
        { "include": "#statement" }
      ]
    },

    "parameter-list": {
      "begin": "\\(",
      "end": "\\)",
      "beginCaptures": { "0": { "name": "punctuation.definition.parameters.begin.luau" } },
      "endCaptures":   { "0": { "name": "punctuation.definition.parameters.end.luau" } },
      "patterns": [
        { "include": "#comment" },
        { "name": "variable.language.vararg.luau", "match": "\\.\\.\\." },
        {
          "match": "([A-Za-z_][A-Za-z0-9_]*)\\s*(:)",
          "captures": {
            "1": { "name": "variable.parameter.luau" },
            "2": { "name": "punctuation.separator.type.luau" }
          }
        },
        {
          "name": "variable.parameter.luau",
          "match": "[A-Za-z_][A-Za-z0-9_]*"
        },
        {
          "begin": "(?<=:)",
          "end": "(?=,|\\)|=)",
          "patterns": [{ "include": "#type-expression" }]
        }
      ]
    },

    "return-type-annotation": {
      "begin": "(?<=\\))\\s*(:)\\s*",
      "beginCaptures": { "1": { "name": "punctuation.separator.type.luau" } },
      "end": "(?=$|\\blocal\\b|\\breturn\\b|\\bif\\b|\\bfor\\b|\\bwhile\\b|\\bdo\\b|\\bend\\b|\\brepeat\\b)",
      "patterns": [{ "include": "#type-expression" }]
    },

    "local-declaration": {
      "name": "meta.declaration.local.luau",
      "begin": "\\b(local)\\b",
      "beginCaptures": { "1": { "name": "storage.modifier.local.luau" } },
      "end": "(?=$|;|=)",
      "patterns": [
        { "include": "#attribute" },
        {
          "match": "([A-Za-z_][A-Za-z0-9_]*)\\s*(:)",
          "captures": {
            "1": { "name": "variable.other.local.luau" },
            "2": { "name": "punctuation.separator.type.luau" }
          }
        },
        {
          "name": "variable.other.local.luau",
          "match": "[A-Za-z_][A-Za-z0-9_]*"
        },
        {
          "begin": "(?<=:)",
          "end": "(?=,|=|$)",
          "patterns": [{ "include": "#type-expression" }]
        },
        { "include": "#comment" }
      ]
    },

    "attribute": {
      "match": "<\\s*(const|close)\\s*>",
      "captures": { "1": { "name": "storage.modifier.attribute.luau" } }
    },

    "table-constructor": {
      "name": "meta.table.luau",
      "begin": "\\{",
      "end": "\\}",
      "beginCaptures": { "0": { "name": "punctuation.definition.table.begin.luau" } },
      "endCaptures":   { "0": { "name": "punctuation.definition.table.end.luau" } },
      "patterns": [
        { "include": "#comment" },
        {
          "name": "meta.table.field.computed.luau",
          "begin": "\\[",
          "end": "\\]\\s*(=)?",
          "endCaptures": { "1": { "name": "keyword.operator.assignment.luau" } },
          "patterns": [{ "include": "#expression" }]
        },
        {
          "match": "([A-Za-z_][A-Za-z0-9_]*)\\s*(=)",
          "captures": {
            "1": { "name": "variable.other.property.luau" },
            "2": { "name": "keyword.operator.assignment.luau" }
          }
        },
        { "name": "punctuation.separator.table.luau", "match": ",|;" },
        { "include": "#expression" }
      ]
    },

    "typeof-call": {
      "match": "\\b(typeof)\\s*(?=\\()",
      "captures": { "1": { "name": "support.function.typeof.luau" } }
    },

    "function-call": {
      "match": "(?<![:.\\w])([A-Za-z_][A-Za-z0-9_]*)\\s*(?=[\\(\\{\"'`])",
      "captures": { "1": { "name": "entity.name.function.luau" } }
    },

    "property-call": {
      "match": "(\\.|:)\\s*([A-Za-z_][A-Za-z0-9_]*)\\s*(?=[\\(\\{\"'`])",
      "captures": {
        "1": { "name": "punctuation.accessor.luau" },
        "2": { "name": "entity.name.function.luau" }
      }
    },

    "property-access": {
      "match": "(\\.|:)\\s*([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "punctuation.accessor.luau" },
        "2": { "name": "variable.other.property.luau" }
      }
    },

    "stdlib-namespace": {
      "name": "support.class.luau",
      "match": "(?<![:.\\w])(coroutine|debug|math|string|table|utf8|bit32|buffer|vector)\\b"
    },

    "stdlib-roblox-namespace": {
      "name": "support.class.roblox.luau",
      "match": "(?<![:.\\w])(task|bit)\\b"
    },

    "stdlib-global": {
      "name": "support.function.builtin.luau",
      "match": "(?<![:.\\w])(assert|collectgarbage|error|gcinfo|getfenv|getmetatable|ipairs|newproxy|next|pairs|pcall|print|rawequal|rawget|rawlen|rawset|require|select|setfenv|setmetatable|tonumber|tostring|type|typeof|unpack|xpcall)\\b"
    },

    "stdlib-constant": {
      "name": "support.variable.builtin.luau",
      "match": "(?<![:.\\w])(_G|_VERSION)\\b"
    },

    "stdlib-roblox-global": {
      "name": "support.function.builtin.roblox.luau",
      "match": "(?<![:.\\w])(warn)\\b"
    },

    "roblox-datamodel-global": {
      "name": "support.variable.roblox.luau",
      "match": "(?<![:.\\w])(game|workspace|script|shared|plugin|Instance|Enum|Vector2|Vector3|CFrame|UDim|UDim2|Color3|BrickColor|Rect|Region3|Ray|NumberRange|NumberSequence|ColorSequence|Random|TweenInfo)\\b"
    },

    "identifier": {
      "name": "variable.other.luau",
      "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
    }
  }
}
